{
	"name": "@panoscool/query-string",
	"version": "0.2.0",
	"license": "MIT",
	"description": "A TypeScript library to parse and stringify URL query strings.",
	"funding": "https://github.com/sponsors/panoscool",
	"homepage": "https://github.com/panoscool/query-string#readme",
	"author": {
		"name": "Lavdimir Kullolli",
		"email": "lkullolli@gmail.com",
		"url": "https://panoscool.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/panoscool/query-string.git"
	},
	"bugs": {
		"url": "https://github.com/panoscool/query-string/issues"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"scripts": {
		"test": "bun test",
		"build": "bun build.ts",
		"verify": "node verify.mjs",
		"prepublishOnly": "npm run build",
		"release": "bash ./scripts/release.sh",
		"lint": "biome check",
		"format": "biome format --write"
	},
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"query",
		"string",
		"params",
		"url",
		"parse",
		"encode",
		"decode",
		"parameter",
		"stringify",
		"querystring",
		"searchparams",
		"query-string",
		"urlsearchparams"
	],
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/bun": "1.3.14",
		"typescript": "6.0.3"
	}
}
